@model Computer_Security_2FA.Models.RegisterViewModel

@{
    ViewData["Title"] = "Yeni Kayıt";
}

<div style="max-width:450px; margin:60px auto; padding:30px; border:1px solid #ddd; border-radius:10px; text-align:center;">
    <h2>Yeni Kayıt</h2>

    <form method="post" action="/Auth/Register">
        <div style="margin-bottom:15px;">
            <input asp-for="UserName" placeholder="Kullanıcı Adı" style="width:100%; padding:10px;" />
            <span asp-validation-for="UserName" style="color:red;"></span>
        </div>

        <div style="margin-bottom:15px;">
            <input asp-for="Password" type="password" placeholder="Şifre" style="width:100%; padding:10px;" />
            <span asp-validation-for="Password" style="color:red;"></span>
        </div>

        <div style="display:flex; gap:10px; justify-content:center;">
            <button type="submit" style="padding:10px 20px;">Kayıt Ol</button>
            <a href="/Auth/Login" style="padding:10px 20px; border:1px solid #999; text-decoration:none;">Girişe Dön</a>
        </div>
    </form>

    <p style="color:red; margin-top:15px;">@ViewBag.Message</p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}