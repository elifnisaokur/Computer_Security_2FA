@model Computer_Security_2FA.Models.UserLogsViewModel

<h2>Welcome</h2>

<p>Hoş geldin, <strong>@Model.UserName</strong></p>

<p>
    <a asp-action="Logout">Logout</a>
</p>

<h3>Son Giriş Kayıtları</h3>

@if (Model.Logs == null || !Model.Logs.Any())
{
    <p>Henüz log kaydı bulunmuyor.</p>
}
else
{
    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>Zaman (UTC)</th>
                <th>Durum</th>
                <th>Olay Tipi</th>
                <th>Hata Nedeni</th>
                <th>IP Adresi</th>
                <th>Remember Device</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td>@log.AttemptTimeUtc</td>
                    <td>@(log.IsSuccess ? "Başarılı" : "Başarısız")</td>
                    <td>@log.EventType</td>
                    <td>@log.FailureReason</td>
                    <td>@log.IpAddress</td>
                    <td>@(log.RememberDeviceUsed ? "Evet" : "Hayır")</td>
                </tr>
            }
        </tbody>
    </table>
}