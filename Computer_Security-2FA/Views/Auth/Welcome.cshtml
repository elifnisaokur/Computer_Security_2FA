@model Computer_Security_2FA.Models.UserLogsViewModel

<h2>Welcome</h2>

<p>Welcome, <strong>@Model.UserName</strong></p>

<p>
    <a asp-action="Logout">Logout</a>
</p>

<h3>Last Login Records</h3>

@if (Model.Logs == null || !Model.Logs.Any())
{
    <p>No log records yet.</p>
}
else
{
    <table border="1" cellpadding="8" cellspacing="0">
        <thead>
            <tr>
                <th>Time (UTC)</th>
                <th>Situation</th>
                <th>Event Type</th>
                <th>Reason for Error</th>
                <th>IP Address</th>
                <th>Remember Device</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.Logs)
            {
                <tr>
                    <td>@log.AttemptTimeUtc</td>
                    <td>@(log.IsSuccess ? "Successful" : "Unsuccessful")</td>
                    <td>@log.EventType</td>
                    <td>@log.FailureReason</td>
                    <td>@log.IpAddress</td>
                    <td>@(log.RememberDeviceUsed ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}